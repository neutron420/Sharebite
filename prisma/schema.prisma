generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DONOR
  NGO
  ADMIN
}

enum DonationStatus {
  AVAILABLE
  REQUESTED
  APPROVED
  COLLECTED
  EXPIRED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum FoodCategory {
  VEG
  NON_VEG
  DAIRY
  BAKERY
  FRUITS_AND_VEGGIES
  COOKED_FOOD
  STAPLES
  PACKAGED_FOOD
  OTHERS
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        UserRole @default(DONOR)
  phoneNumber String?
  address     String?
  city        String?
  imageUrl    String?

  donations FoodDonation[]  @relation("DonorDonations")
  requests  PickupRequest[] @relation("NGORequests")

  reviewsGiven    Review[] @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model FoodDonation {
  id             String         @id @default(uuid())
  title          String
  description    String
  quantity       Int
  category       FoodCategory
  expiryTime     DateTime
  pickupStartTime DateTime
  pickupEndTime   DateTime
  pickupLocation String
  latitude       Float?
  longitude      Float?
  imageUrl       String?
  status         DonationStatus @default(AVAILABLE)

  donorId  String
  donor    User            @relation("DonorDonations", fields: [donorId], references: [id], onDelete: Cascade)
  requests PickupRequest[]
  reviews  Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([expiryTime])
  @@index([latitude, longitude])
  @@index([category])
}

model PickupRequest {
  id      String        @id @default(uuid())
  message String?
  status  RequestStatus @default(PENDING)

  ngoId      String
  ngo        User         @relation("NGORequests", fields: [ngoId], references: [id], onDelete: Cascade)
  donationId String
  donation   FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ngoId, donationId])
  @@index([status])
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String? @db.Text

  reviewerId String
  reviewer   User         @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User         @relation("Reviewee", fields: [revieweeId], references: [id])
  donationId String
  donation   FoodDonation @relation(fields: [donationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewerId, donationId])
  @@index([revieweeId])
  @@index([donationId])
}
