generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id @default(uuid())
  email                String          @unique
  password             String
  name                 String
  role                 UserRole        @default(DONOR)
  phoneNumber          String?
  address              String?
  city                 String?
  imageUrl             String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  isVerified           Boolean         @default(false)
  verificationDoc      String?
  district             String?
  latitude             Float?
  longitude            Float?
  pincode              String?
  state                String?
  isLicenseSuspended   Boolean         @default(false)
  strikeCount          Int             @default(0)
  suspensionExpiresAt  DateTime?
  isAvailable          Boolean         @default(true)
  rating               Float           @default(5.0)
  totalDeliveries      Int             @default(0)
  donorType            String?
  karmaPoints          Int             @default(0)
  level                Int             @default(1)
  auditLogs            AuditLog[]
  bugReports           BugReport[]
  bugResponses         BugResponse[]
  conversationsAsA     Conversation[]  @relation("ParticipantA")
  conversationsAsB     Conversation[]  @relation("ParticipantB")
  donorReportsReceived DonorReport[]   @relation("ReportedDonor")
  donorReportsMade     DonorReport[]   @relation("DonorReporter")
  donations            FoodDonation[]  @relation("DonorDonations")
  sentMessages         Message[]
  notifications        Notification[]
  requests             PickupRequest[] @relation("NGORequests")
  tasks                PickupRequest[] @relation("RiderTasks")
  reports              Report[]        @relation("ReportedUser")
  reportsMade          Report[]        @relation("Reporter")
  reviewsReceived      Review[]        @relation("Reviewee")
  reviewsGiven         Review[]        @relation("Reviewer")
  badges               UserBadge[]
  violations           Violation[]     @relation("UserViolations")
  payments             Payment[]       @relation("UserPayments")
  wallet               Wallet?
  rewardPoints         Int             @default(0)

  @@index([email])
  @@index([role])
  @@index([isVerified])
}

model BugReport {
  id          String        @id @default(uuid())
  type        BugType
  description String
  location    String?
  status      BugStatus     @default(PENDING)
  reporterId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reporter    User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  responses   BugResponse[]

  @@index([status])
  @@index([type])
  @@index([reporterId])
}

model BugResponse {
  id          String    @id @default(uuid())
  message     String
  adminId     String
  bugReportId String
  createdAt   DateTime  @default(now())
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  bugReport   BugReport @relation(fields: [bugReportId], references: [id], onDelete: Cascade)

  @@index([bugReportId])
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  imageUrl    String?
  criteria    Json?
  createdAt   DateTime    @default(now())
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model FoodDonation {
  id              String          @id @default(uuid())
  title           String
  description     String
  expiryTime      DateTime
  pickupLocation  String
  latitude        Float?
  longitude       Float?
  imageUrl        String?
  status          DonationStatus  @default(AVAILABLE)
  donorId         String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  pickupEndTime   DateTime
  pickupStartTime DateTime
  quantity        Int
  category        FoodCategory
  weight          Float?          @default(0)
  city            String
  district        String?
  pincode         String?
  state           String?
  conversations   Conversation[]
  donor           User            @relation("DonorDonations", fields: [donorId], references: [id], onDelete: Cascade)
  requests        PickupRequest[]
  reviews         Review[]

  @@index([status])
  @@index([expiryTime])
  @@index([latitude, longitude])
  @@index([category])
}

model PickupRequest {
  id               String        @id @default(uuid())
  message          String?
  status           RequestStatus @default(PENDING)
  ngoId            String
  donationId       String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deliveryImageUrl String?
  handoverPin      String?
  step             Float         @default(1)
  completedAt      DateTime?
  pickedUpAt       DateTime?
  riderId          String?
  donation         FoodDonation  @relation(fields: [donationId], references: [id], onDelete: Cascade)
  ngo              User          @relation("NGORequests", fields: [ngoId], references: [id], onDelete: Cascade)
  rider            User?         @relation("RiderTasks", fields: [riderId], references: [id])
  paymentId        String?
  payment          Payment?      @relation(fields: [paymentId], references: [id])
  otps             OTPVerification[]

  @@unique([ngoId, donationId])
  @@index([status])
}

model Review {
  id         String       @id @default(uuid())
  rating     Int
  comment    String?
  reviewerId String
  revieweeId String
  donationId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  donation   FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  reviewee   User         @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User         @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, donationId])
  @@index([revieweeId])
  @@index([donationId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  details   String?
  ipAddress String?
  adminId   String
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([action])
  @@index([adminId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  userId    String
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Conversation {
  id             String       @id @default(uuid())
  donationId     String
  participantAId String
  participantBId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  donation       FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  participantA   User         @relation("ParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User         @relation("ParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([donationId, participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  text           String?
  senderId       String
  conversationId String
  imageUrl       String?
  locationLat    Float?
  locationLng    Float?
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Violation {
  id        String   @id @default(uuid())
  level     Int
  reason    String
  adminId   String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation("UserViolations", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id         String   @id @default(uuid())
  reason     String
  details    String?
  status     String   @default("PENDING")
  reporterId String
  ngoId      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ngo        User     @relation("ReportedUser", fields: [ngoId], references: [id], onDelete: Cascade)
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([ngoId])
  @@index([status])
}

model DonorReport {
  id         String   @id @default(uuid())
  reason     String
  details    String?
  status     String   @default("PENDING")
  reporterId String
  donorId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  donor      User     @relation("ReportedDonor", fields: [donorId], references: [id], onDelete: Cascade)
  reporter   User     @relation("DonorReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([donorId])
  @@index([status])
}

enum NotificationType {
  REQUEST_STATUS
  NEW_DONATION
  URGENT_EXPIRY
  SYSTEM
  BUG_RESPONSE
}

enum BugType {
  TECHNICAL
  UI_UX
  PERFORMANCE
  SECURITY
  OTHER
}

enum BugStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

enum UserRole {
  DONOR
  NGO
  ADMIN
  RIDER
}

enum DonationStatus {
  AVAILABLE
  REQUESTED
  APPROVED
  COLLECTED
  EXPIRED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  ASSIGNED
  ON_THE_WAY
}

enum FoodCategory {
  VEG
  NON_VEG
  DAIRY
  BAKERY
  FRUITS_AND_VEGGIES
  COOKED_FOOD
  STAPLES
  PACKAGED_FOOD
  BEVERAGES
  CANNED_GOODS
  FROZEN_FOOD
  OTHERS
}

model Payment {
  id                String        @id @default(uuid())
  amount            Float
  currency          String        @default("INR")
  razorpayOrderId   String        @unique
  razorpayPaymentId String?      @unique
  status            PaymentStatus @default(PENDING)
  userId            String       
  user              User          @relation("UserPayments", fields: [userId], references: [id])
  requests          PickupRequest[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([userId])
}

model Wallet {
  id              String   @id @default(uuid())
  riderId         String   @unique
  rider           User     @relation(fields: [riderId], references: [id])
  balance         Float    @default(0.0)
  totalEarnings   Float    @default(0.0)
  transactions    Transaction[]
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(uuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id])
  amount    Float
  type      String   
  purpose   String   
  createdAt DateTime @default(now())
}

model OTPVerification {
  id        String   @id @default(uuid())
  otp       String
  expiry    DateTime
  orderId   String
  order     PickupRequest @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
