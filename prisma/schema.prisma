generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  REQUEST_STATUS
  NEW_DONATION
  URGENT_EXPIRY
  SYSTEM
}

enum UserRole {
  DONOR
  NGO
  ADMIN
}

enum DonationStatus {
  AVAILABLE
  REQUESTED
  APPROVED
  COLLECTED
  EXPIRED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum FoodCategory {
  VEG
  NON_VEG
  DAIRY
  BAKERY
  FRUITS_AND_VEGGIES
  COOKED_FOOD
  STAPLES
  PACKAGED_FOOD
  OTHERS
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        UserRole @default(DONOR)
  phoneNumber String?
  address     String?
  city        String?
  imageUrl    String?

  isVerified      Boolean @default(false)
  verificationDoc String?

  donations FoodDonation[]  @relation("DonorDonations")
  requests  PickupRequest[] @relation("NGORequests")

  reviewsGiven    Review[] @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewee")

  auditLogs     AuditLog[]
  notifications Notification[]

  // Chat relations
  sentMessages     Message[]
  conversationsAsA Conversation[] @relation("ParticipantA")
  conversationsAsB Conversation[] @relation("ParticipantB")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isVerified])
}

model FoodDonation {
  id              String         @id @default(uuid())
  title           String
  description     String
  quantity        Int
  weight          Float?         @default(0)
  category        FoodCategory
  expiryTime      DateTime
  pickupStartTime DateTime
  pickupEndTime   DateTime
  pickupLocation  String
  city            String
  latitude        Float?
  longitude       Float?
  imageUrl        String?
  status          DonationStatus @default(AVAILABLE)

  donorId       String
  donor         User            @relation("DonorDonations", fields: [donorId], references: [id], onDelete: Cascade)
  requests      PickupRequest[]
  reviews       Review[]
  conversations Conversation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([expiryTime])
  @@index([latitude, longitude])
  @@index([category])
}

model PickupRequest {
  id      String        @id @default(uuid())
  message String?
  status  RequestStatus @default(PENDING)

  ngoId      String
  ngo        User         @relation("NGORequests", fields: [ngoId], references: [id], onDelete: Cascade)
  donationId String
  donation   FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ngoId, donationId])
  @@index([status])
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String? @db.Text

  reviewerId String
  reviewer   User         @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User         @relation("Reviewee", fields: [revieweeId], references: [id])
  donationId String
  donation   FoodDonation @relation(fields: [donationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewerId, donationId])
  @@index([revieweeId])
  @@index([donationId])
}

model AuditLog {
  id        String  @id @default(uuid())
  action    String
  details   String? @db.Text
  ipAddress String?

  adminId String
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([action])
  @@index([adminId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

model Conversation {
  id         String       @id @default(uuid())
  donationId String
  donation   FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  participantAId String
  participantA   User   @relation("ParticipantA", fields: [participantAId], references: [id])
  participantBId String
  participantB   User   @relation("ParticipantB", fields: [participantBId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([donationId, participantAId, participantBId])
}

model Message {
  id             String       @id @default(uuid())
  text           String?      @db.Text
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  imageUrl    String?
  locationLat Float?
  locationLng Float?

  createdAt DateTime @default(now())

  @@index([conversationId])
}
